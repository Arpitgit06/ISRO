# ============================================================
#  TESSERACTZ — .gitignore
# ============================================================

# ─── Node.js / React ─────────────────────────────────────────
node_modules/
build/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Python ──────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
*.whl

# ─── Model Checkpoints & Weights ─────────────────────────────
checkpoints/
*.pt
*.pth
*.onnx
*.bin
*.safetensors

# ─── Torch Hub Cache ─────────────────────────────────────────
.cache/

# ─── IDE & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── OS Generated ────────────────────────────────────────────
*.lnk
ehthumbs.db
ehthumbs_vista.db

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/

# ─── Test / Coverage ─────────────────────────────────────────
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.coverage

# ─── Docker ──────────────────────────────────────────────────
docker-compose.override.yml

# ─── Uploaded / Processed Images (runtime data) ──────────────
mnt/
uploads/
outputs/

# ─── Temp / Scratch ──────────────────────────────────────────
*.tmp
*.bak
cleanup_duplicates.bat
